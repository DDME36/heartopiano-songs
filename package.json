{
  "name": "heartopiano",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Auto Piano Player for Heartopia Game",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "keywords": [
    "electron",
    "piano",
    "automation",
    "heartopia"
  ],
  "author": "PUNN",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "javascript-obfuscator": "^5.2.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "terser": "^5.46.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^7.2.0",
    "webpack-obfuscator": "^3.6.0"
  },
  "dependencies": {
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.563.0",
    "node-key-sender": "^1.0.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.heartopiano.app",
    "productName": "HEARTOPIANO BY PUNN",
    "win": {
      "target": ["nsis"],
      "icon": "public/icon.ico",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HEARTOPIANO BY PUNN",
      "artifactName": "HEARTOPIANO-BY-PUNN-Setup.exe"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!songs/**/*"
    ],
    "extraResources": [
      {
        "from": "python-embed",
        "to": "python-embed",
        "filter": ["**/*"]
      }
    ],
    "extraFiles": [
      {
        "from": "electron/sender.py",
        "to": "electron/sender.py"
      }
    ]
  }
}
